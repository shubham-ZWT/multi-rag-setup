    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"securepassword\",\n  \"fullName\": \"John Doe\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "response": [
            {
              "name": "Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"User registered successfully\"\n}"
            },
            {
              "name": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"Email, password, and full name are required\"\n}"
            }
          ]
        },
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"securepassword\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "response": [
            {
              "name": "Success",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"User logged in successfully\",\n  \"token\": \"eyJhbGciOiJIUzI1NiIs...\"\n}"
            },
            {
              "name": "Unauthorized",
              "code": 401,
              "body": "{\n  \"error\": \"Invalid email or password\"\n}"
            }
          ]
        },
        {
          "name": "GET Protected Route",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/protected",
              "host": ["{{baseUrl}}"],
              "path": ["api", "protected"]
            }
          },
          "response": [
            {
              "name": "Success",
              "code": 200,
              "body": "{\n  \"message\": \"This is a protected route\"\n}"
            }
          ]
        },
        {
          "name": "GET Admin Route",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin"]
            }
          },
          "response": [
            {
              "name": "Success (admin only)",
              "code": 200,
              "body": "{\n  \"message\": \"This is an admin-only route\"\n}"
            },
            {
              "name": "Forbidden (non-admin)",
              "code": 403,
              "body": "{\n  \"error\": \"Forbidden: insufficient permissions\"\n}"
            }
          ]
        },
        {
          "name": "POST Forgot Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.collectionVariables.set('resetToken', jsonData.resetToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "forgot-password"]
            }
          },
          "response": [
            {
              "name": "Success",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Password reset token generated successfully\",\n  \"resetToken\": \"a1b2c3d4e5f6...\"\n}"
            },
            {
              "name": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"Email is required\"\n}"
            }
          ]
        },
        {
          "name": "POST Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPassword\": \"mynewsecurepassword\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/reset-password/{{resetToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "reset-password", "{{resetToken}}"]
            }
          },
          "response": [
            {
              "name": "Success",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Password reset successfully\"\n}"
            },
            {
              "name": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"Invalid or expired reset token\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Bots",
      "item": [
        {
          "name": "POST Create Bot",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.collectionVariables.set('botId', jsonData.bot.id);",
                  "  pm.collectionVariables.set('embedKey', jsonData.bot.embedKey);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Support Bot\",\n  \"slug\": \"my-support-bot\",\n  \"systemPrompt\": \"You are a helpful customer support assistant. Answer questions based on the provided context.\",\n  \"model\": \"gemini-2.0-flash\",\n  \"temperature\": 0.7,\n  \"maxTokens\": 2048,\n  \"isPublic\": true,\n  \"allowedDomains\": [\"example.com\"],\n  \"widgetConfig\": {\n    \"primaryColor\": \"#4F46E5\",\n    \"position\": \"right\",\n    \"greeting\": \"Hello! How can I help you?\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/bots/create",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bots", "create"]
            }
          },
          "response": [
            {
              "name": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"Bot created successfully\",\n  \"bot\": {\n    \"id\": \"uuid\",\n    \"userId\": \"uuid\",\n    \"name\": \"My Support Bot\",\n    \"slug\": \"my-support-bot\",\n    \"embedKey\": \"emb_...\",\n    \"status\": \"draft\",\n    \"isPublic\": true,\n    \"allowedDomains\": [\"example.com\"],\n    \"widgetConfig\": { ... },\n    ...\n  }\n}"
            },
            {
              "name": "Conflict (slug exists)",
              "code": 409,
              "body": "{\n  \"error\": \"A bot with this slug already exists\"\n}"
            }
          ]
        },
        {
          "name": "PUT Update Bot",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Updated Bot\",\n  \"systemPrompt\": \"You are an expert assistant.\",\n  \"temperature\": 0.5,\n  \"status\": \"published\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/bots/{{botId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bots", "{{botId}}"]
            }
          },
          "response": [
            {
              "name": "Success",
              "code": 200,
              "body": "{\n  \"message\": \"Bot updated successfully\",\n  \"bot\": { ... }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Knowledge Sources",
      "item": [
        {
          "name": "POST Add Text",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.collectionVariables.set('knowledgeSourceId', jsonData.source.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"botId\": \"{{botId}}\",\n  \"name\": \"Earth Facts\",\n  \"content\": \"The Earth is the third planet from the Sun and the only known planet to harbor life. About 71% of Earth's surface is covered with water, mostly by oceans. The remaining 29% is land consisting of continents and islands. Earth's atmosphere is composed mostly of nitrogen and oxygen. Earth's gravity interacts with other objects in space, especially the Sun and the Moon.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/knowledge-sources/text",
              "host": ["{{baseUrl}}"],
              "path": ["api", "knowledge-sources", "text"]
            }
          },
          "response": [
            {
              "name": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"Text added and indexed successfully\",\n  \"source\": {\n    \"id\": \"uuid\",\n    \"botId\": \"uuid\",\n    \"sourceType\": \"text\",\n    \"name\": \"Earth Facts\",\n    \"chunkCount\": 2,\n    \"indexStatus\": \"completed\",\n    ...\n  }\n}"
            }
          ]
        },
        {
          "name": "POST Upload File",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "botId", "value": "{{botId}}", "type": "text" },
                {
                  "key": "file",
                  "type": "file",
                  "src": "/path/to/your/file.pdf"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/knowledge-sources/upload",
              "host": ["{{baseUrl}}"],
              "path": ["api", "knowledge-sources", "upload"]
            }
          },
          "response": [
            {
              "name": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"File uploaded and indexed successfully\",\n  \"source\": { ... }\n}"
            },
            {
              "name": "Bad Request (no file)",
              "code": 400,
              "body": "{\n  \"error\": \"File is required\"\n}"
            }
          ]
        },
        {
          "name": "POST Add URL",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"botId\": \"{{botId}}\",\n  \"url\": \"https://en.wikipedia.org/wiki/Earth\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/knowledge-sources/url",
              "host": ["{{baseUrl}}"],
              "path": ["api", "knowledge-sources", "url"]
            }
          },
          "response": [
            {
              "name": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"URL fetched and indexed successfully\",\n  \"source\": { ... }\n}"
            }
          ]
        },
        {
          "name": "GET List Sources",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/knowledge-sources?botId={{botId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "knowledge-sources"],
              "query": [{ "key": "botId", "value": "{{botId}}" }]
            }
          },
          "response": [
            {
              "name": "Success",
              "code": 200,
              "body": "[\n  {\n    \"id\": \"uuid\",\n    \"botId\": \"uuid\",\n    \"sourceType\": \"text\",\n    \"name\": \"Earth Facts\",\n    \"chunkCount\": 2,\n    \"indexStatus\": \"completed\",\n    ...\n  }\n]"
            }
          ]
        },
        {
          "name": "GET Single Source",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/knowledge-sources/{{knowledgeSourceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "knowledge-sources", "{{knowledgeSourceId}}"]
            }
          },
          "response": [
            {
              "name": "Success",
              "code": 200,
              "body": "{\n  \"id\": \"uuid\",\n  \"botId\": \"uuid\",\n  \"sourceType\": \"text\",\n  \"name\": \"Earth Facts\",\n  \"contentRaw\": \"...\",\n  \"chunkCount\": 2,\n  \"indexStatus\": \"completed\",\n  ...\n}"
            }
          ]
        },
        {
          "name": "POST Reindex Source",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/knowledge-sources/{{knowledgeSourceId}}/reindex",
              "host": ["{{baseUrl}}"],
              "path": [
                "api",
                "knowledge-sources",
                "{{knowledgeSourceId}}",
                "reindex"
              ]
            }
          },
          "response": [
            {
              "name": "Success",
              "code": 200,
              "body": "{\n  \"message\": \"Source reindexed successfully\",\n  \"source\": { ... }\n}"
            }
          ]
        },
        {
          "name": "DELETE Source",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/knowledge-sources/{{knowledgeSourceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "knowledge-sources", "{{knowledgeSourceId}}"]
            }
          },
          "response": [
            {
              "name": "Success",
              "code": 200,
              "body": "{\n  \"message\": \"Knowledge source deleted successfully\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "POST Send Message",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.collectionVariables.set('conversationId', jsonData.conversationId);",
                  "  pm.collectionVariables.set('messageId', jsonData.messageId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"visitor-session-123\",\n  \"visitorId\": \"visitor-456\",\n  \"message\": \"Tell me about Earth\",\n  \"pageUrl\": \"https://example.com/contact\",\n  \"referrer\": \"https://google.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/chat/{{botId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "chat", "{{botId}}"]
            }
          },
          "response": [
            {
              "name": "Success",
              "code": 200,
              "body": "{\n  \"reply\": \"The Earth is the third planet from the Sun...\",\n  \"sources\": [\n    { \"content\": \"...\", \"chunkIndex\": 0 }\n  ],\n  \"conversationId\": \"uuid\",\n  \"messageId\": \"uuid\"\n}"
            },
            {
              "name": "Bot Not Found",
              "code": 404,
              "body": "{\n  \"error\": \"Bot not found\"\n}"
            }
          ]
        },
        {
          "name": "GET Conversation Messages",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/chat/conversations/{{conversationId}}/messages",
              "host": ["{{baseUrl}}"],
              "path": [
                "api",
                "chat",
                "conversations",
                "{{conversationId}}",
                "messages"
              ]
            }
          },
          "response": [
            {
              "name": "Success",
              "code": 200,
              "body": "[\n  {\n    \"id\": \"uuid\",\n    \"conversationId\": \"uuid\",\n    \"role\": \"user\",\n    \"content\": \"Tell me about Earth\",\n    \"createdAt\": \"...\"\n  },\n  {\n    \"id\": \"uuid\",\n    \"conversationId\": \"uuid\",\n    \"role\": \"assistant\",\n    \"content\": \"The Earth is the third planet...\",\n    \"sourcesUsed\": [...],\n    \"createdAt\": \"...\"\n  }\n]"
            }
          ]
        }
      ]
    },
